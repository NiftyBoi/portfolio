# Variables de entorno para Vercel Serverless Functions (configurar en panel de Vercel)

# Gmail desde donde se envían los correos del formulario de contacto
EMAIL_USER=tu-correo@gmail.com

# App Password de Gmail (16 caracteres, requiere verificación en 2 pasos)
# Generar en: Google Account → Seguridad → Contraseñas de aplicaciones
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Correo destino donde recibes los mensajes del formulario
EMAIL_TO=tu-correo-destino@gmail.com
